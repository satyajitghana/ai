{
  "description": "brand-crew — validate-on-save: after any edit to a content/ or data/ file, run pnpm validate:content so a broken frontmatter or typed-data edit fails loudly before it can be committed.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-content.sh\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
